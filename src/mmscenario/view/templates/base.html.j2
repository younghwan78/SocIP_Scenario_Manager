<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ scenario.scenario.name }}</title>
<style>
  /* ── Reset & base ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px;
         background: #f5f7fa; color: #333; display: flex; flex-direction: column; height: 100vh; }

  /* ── Header ── */
  header { background: #1a2a4a; color: #fff; padding: 10px 20px;
           display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
  header h1 { font-size: 16px; font-weight: 600; }
  header .meta { font-size: 12px; color: #aac; }
  header .spacer { flex: 1; }

  /* ── Tab bar ── */
  .tab-bar { background: #253555; display: flex; gap: 2px; padding: 0 20px; flex-shrink: 0; }
  .tab { padding: 8px 18px; cursor: pointer; color: #8aa; font-size: 13px;
         border-bottom: 3px solid transparent; user-select: none; }
  .tab:hover { color: #fff; }
  .tab.active { color: #fff; border-bottom-color: #5b9bd5; }

  /* ── Main layout ── */
  .main { display: flex; flex: 1; overflow: hidden; }

  /* ── Toolbar ── */
  .toolbar { background: #fff; border-bottom: 1px solid #dde;
             padding: 6px 16px; display: flex; align-items: center; gap: 12px;
             flex-shrink: 0; flex-wrap: wrap; }
  .toolbar label { font-size: 12px; color: #666; }
  .toolbar select, .toolbar button { font-size: 12px; padding: 3px 8px; border: 1px solid #ccc;
                                      border-radius: 3px; cursor: pointer; background: #fff; }
  .toolbar button:hover { background: #eef; }
  .layer-toggle { display: flex; gap: 8px; }
  .layer-group-label { font-size: 10px; color: #aaa; align-self: center; }
  .layer-btn { padding: 3px 10px; border-radius: 12px; border: 1px solid #ccc;
               cursor: pointer; font-size: 11px; background: #fff; }
  .layer-btn.active { color: #fff; border-color: transparent; }
  .layer-btn[data-layer="app"].active       { background: #8e44ad; }
  .layer-btn[data-layer="framework"].active { background: #2980b9; }
  .layer-btn[data-layer="hal"].active       { background: #16a085; }
  .layer-btn[data-layer="kernel"].active    { background: #2c3e50; }
  .layer-btn[data-layer="hw"].active        { background: #E67E22; }
  .layer-btn[data-layer="memory"].active    { background: #27AE60; }

  /* ── Graph + panel ── */
  .graph-area { display: flex; flex: 1; overflow: hidden; }
  #cy { flex: 1; background: #fafbfd; position: relative; }
  .detail-panel { width: 280px; background: #fff; border-left: 1px solid #dde;
                  overflow-y: auto; padding: 16px; flex-shrink: 0; }
  .detail-panel h3 { font-size: 13px; color: #1a2a4a; margin-bottom: 10px; }
  .prop-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .prop-table td { padding: 4px 6px; border-bottom: 1px solid #eee; vertical-align: top; }
  .prop-table td:first-child { color: #777; width: 45%; font-weight: 500; }
  .review-flag { background: #fff3cd; border-radius: 3px; padding: 2px 6px;
                 font-size: 11px; color: #856404; margin-top: 4px; display: block; }
  .empty-hint { color: #aaa; font-size: 12px; margin-top: 20px; text-align: center; }

  /* ── Layer lane backgrounds ── */
  .lane-label { position: absolute; left: 4px; font-size: 10px; font-weight: 600;
                color: #888; pointer-events: none; z-index: 10; }

  /* ── Variant selector ── */
  #variant-section { margin-top: 12px; border-top: 1px solid #eee; padding-top: 10px; }
  #variant-table { width: 100%; border-collapse: collapse; font-size: 11px; margin-top: 6px; }
  #variant-table th { background: #f0f4f8; padding: 4px 6px; text-align: left; font-weight: 600; }
  #variant-table td { padding: 4px 6px; border-bottom: 1px solid #eee; }
  .changed { background: #fff3cd; font-weight: 600; }

  /* ── Risk summary ── */
  .risk-section { margin-top: 12px; border-top: 1px solid #eee; padding-top: 10px; }
  .risk-item { border-radius: 4px; padding: 6px 8px; margin-bottom: 6px; font-size: 12px; }
  .risk-high   { background: #fde8e8; border-left: 3px solid #e74c3c; }
  .risk-medium { background: #fef3cd; border-left: 3px solid #f39c12; }
  .risk-low    { background: #e8f8ee; border-left: 3px solid #27ae60; }

  /* ── Node badges (C / L / R) ── */
  .node-badge {
    position: absolute;
    width: 13px; height: 13px;
    font-size: 8px; font-weight: 700;
    line-height: 13px; text-align: center;
    border-radius: 3px;
    color: #fff;
    pointer-events: none;
    z-index: 20;
    box-shadow: 0 1px 2px rgba(0,0,0,0.35);
  }

  /* ── Print snapshot ── */
  @media print {
    .toolbar, .tab-bar, .detail-panel, header button { display: none !important; }
    body { background: #fff; }
    #cy { flex: none; width: 100vw; height: 90vh; }
  }
</style>
</head>
<body>

<header>
  <h1>{{ scenario.scenario.name }}{% if active_variant %} <span style="font-size:14px;font-weight:400;opacity:0.75">— {{ active_variant.name }}</span>{% endif %}</h1>
  <span class="meta">v{{ scenario.scenario.version }} · {{ scenario.scenario.category }}</span>
  <span class="meta">output_period: {{ scenario.scenario.output_period_ms }}ms · budget: {{ scenario.scenario.budget_ms }}ms</span>
  <span class="spacer"></span>
  {% if all_variants %}
  <select onchange="if(this.value) window.location.href=this.value"
    style="font-size:12px;padding:4px 8px;border-radius:4px;border:1px solid rgba(255,255,255,0.3);background:rgba(255,255,255,0.1);color:#fff;cursor:pointer;margin-right:8px">
    {% for v in all_variants %}
    <option value="{{ v.html_path }}"{% if active_variant and v.id == active_variant.id %} selected{% endif %}>{{ v.name }}</option>
    {% endfor %}
  </select>
  {% endif %}
  <button onclick="window.print()" style="background:#2a3f6a;color:#fff;border:none;padding:5px 12px;border-radius:3px;cursor:pointer;">⎙ Snapshot</button>
</header>

<div class="tab-bar">
  <div class="tab active" id="tab-executive" onclick="switchMode('executive')">Executive</div>
  <div class="tab"        id="tab-architect" onclick="switchMode('architect')">Architect</div>
</div>

<div class="toolbar">
  <label>Layers:</label>
  <div class="layer-toggle">
    <span class="layer-group-label">SW:</span>
    <button class="layer-btn active" data-layer="app"       onclick="toggleLayer(this)">App</button>
    <button class="layer-btn active" data-layer="framework" onclick="toggleLayer(this)">Framework</button>
    <button class="layer-btn active" data-layer="hal"       onclick="toggleLayer(this)">HAL</button>
    <button class="layer-btn active" data-layer="kernel"    onclick="toggleLayer(this)">Kernel</button>
    <span style="width:1px;background:#dde;align-self:stretch;margin:2px 4px"></span>
    <button class="layer-btn active" data-layer="hw"        onclick="toggleLayer(this)">HW</button>
    <button class="layer-btn active" data-layer="memory"    onclick="toggleLayer(this)">Buffer</button>
  </div>
  <!-- Architect-only: IP focus selector -->
  {% if scenario.ip_activity %}
  <span id="architect-toolbar" style="display:none;gap:8px;align-items:center;margin-left:8px;">
    <label>IP Focus:</label>
    <select id="ip-select" onchange="highlightIP(this.value)">
      <option value="">All</option>
      {% for ip in scenario.ip_activity.ip_instances %}
      <option value="{{ ip.id }}">{{ ip.id }}</option>
      {% endfor %}
    </select>
  </span>
  {% endif %}
  <button id="flow-btn" onclick="toggleDataFlow()"
    style="margin-left:8px;padding:3px 10px;font-size:11px;border-radius:3px;border:1px solid #bbb;background:#f4f6f9;cursor:pointer;"
    title="Animate data flow on data edges">&#9654; Flow</button>
  <span id="toolbar-mode-label" style="font-size:12px;color:#888;margin-left:8px;">
    Executive View — scenario overview &amp; risk summary
  </span>
</div>

<div class="main">
  <div class="graph-area">
    <div id="cy"></div>
  </div>
  <div class="detail-panel" id="detail-panel">
    <h3>Node / Edge Detail</h3>
    <p class="empty-hint">Click a node or edge to see details.</p>

    <!-- Architect-only: IP summary table (always visible in architect mode) -->
    {% if scenario.ip_activity %}
    <div id="ip-summary" style="display:none;margin-top:16px;border-top:1px solid #eee;padding-top:12px;">
      <strong style="font-size:12px;">IP Summary</strong>{% if active_variant %}<span style="font-size:10px;color:#888;margin-left:6px;">({{ active_variant.name }})</span>{% endif %}
      <table class="prop-table" style="margin-top:8px;">
        <tr style="font-size:10px;font-weight:600;color:#555;">
          <td>IP</td><td>freq</td><td>power</td><td>BW R</td><td>BW W</td><td>exec</td><td>src</td>
        </tr>
        {% for ip in scenario.ip_activity.ip_instances %}
        {% set mode = ip.default %}
        <tr>
          <td>{{ ip.id }}</td>
          <td>{{ mode.freq_mhz if mode.freq_mhz is not none else '—' }} <span style="color:#aaa">MHz</span></td>
          <td>{{ mode.power_mA if mode.power_mA is not none else '—' }} <span style="color:#aaa">mA</span></td>
          <td>{{ mode.bw_read_gbps if mode.bw_read_gbps is not none else '—' }} <span style="color:#aaa">GB/s</span></td>
          <td>{{ mode.bw_write_gbps if mode.bw_write_gbps is not none else '—' }} <span style="color:#aaa">GB/s</span></td>
          <td>{{ mode.exec_time_ms if mode.exec_time_ms is not none else '—' }} <span style="color:#aaa">ms</span></td>
          <td>{{ mode.source }}</td>
        </tr>
        {% endfor %}
      </table>
    </div>
    {% endif %}
  </div>
</div>

<!-- Inline Cytoscape.js bundle -->
<script>{{ cytoscape_bundle | safe }}</script>

<script>
// ── Data from Python ──────────────────────────────────────────────
var ELEMENTS   = {{ elements | tojson }};
var SCENARIO   = {{ scenario | tojson }};
var LAYER_Y    = { app: 0, framework: 160, hal: 320, kernel: 480, hw: 680, memory: 980 };
var MODE       = "executive";

// ── Layer background band definitions (module scope — static, never changes) ──
// y1/y2 are model-space midpoints between adjacent LAYER_Y values.
var LAYER_BANDS = [
  { y1: -60,  y2:  80,  color: 'rgba(142,68,173,0.07)'  },  // app
  { y1:  80,  y2: 240,  color: 'rgba(41,128,185,0.07)'  },  // framework
  { y1: 240,  y2: 400,  color: 'rgba(22,160,133,0.07)'  },  // hal
  { y1: 400,  y2: 580,  color: 'rgba(44,62,80,0.06)'    },  // kernel
  { y1: 580,  y2: 830,  color: 'rgba(230,126,34,0.07)'  },  // hw
  { y1: 830,  y2: 1300, color: 'rgba(39,174,96,0.07)'   },  // memory
];

// ── Active variant ip_modes (ip_id → mode_id) ────────────────────
var ACTIVE_IP_MODES = {{ (active_variant.ip_modes if active_variant else {}) | tojson }};

// ── IP activity lookup map (ip_id → IPSpec), built at load time ──
var IP_SPEC_MAP = {};
if (SCENARIO.ip_activity) {
  SCENARIO.ip_activity.ip_instances.forEach(function(spec) {
    IP_SPEC_MAP[spec.id] = spec;
  });
}

// ── DPU composition lookup map (display_id → DpuComposition), built at load time ──
var DPU_COMP_MAP = {};
if (SCENARIO.dpu_compositions) {
  SCENARIO.dpu_compositions.forEach(function(comp) {
    // Pre-sort planes by z_order once here instead of on every click
    comp.planes.sort(function(a, b) { return a.z_order - b.z_order; });
    DPU_COMP_MAP[comp.display_id] = comp;
  });
}

// ── Cytoscape init ───────────────────────────────────────────────
var cy = cytoscape({
  container: document.getElementById('cy'),
  elements: ELEMENTS,
  layout: { name: 'preset' },
  style: [
    {
      selector: 'node',
      style: {
        'label': 'data(label)',
        'shape': 'data(shape)',
        'background-color': 'data(color)',
        'color': '#fff',
        'font-size': '11px',
        'text-valign': 'center',
        'text-halign': 'center',
        'width': 120,
        'height': 40,
        'text-wrap': 'wrap',
        'text-max-width': '110px',
        'border-width': 2,
        'border-color': '#fff',
        'shadow-blur': 7,
        'shadow-color': '#222',
        'shadow-offset-x': 2,
        'shadow-offset-y': 3,
        'shadow-opacity': 0.18,
      }
    },
    {
      selector: 'node[layer="memory"]',
      style: {
        'width': 100,
        'height': 38,
        'font-size': '10px',
      }
    },
    // Cylinder gradient: lighter top → base color → darker bottom
    {
      selector: 'node[type="buffer"]',
      style: {
        'background-fill': 'linear-gradient',
        'background-gradient-direction': 'to-bottom',
        'background-gradient-stop-colors': '#52D68A #27AE60 #1A7A40',
        'background-gradient-stop-positions': '0% 50% 100%',
        'border-color': '#1A7A40',
        'border-width': 1.5,
      }
    },
    {
      selector: 'edge',
      style: {
        'width': 2,
        'line-color': '#aab',
        'target-arrow-color': '#aab',
        'target-arrow-shape': 'triangle',
        'curve-style': 'taxi',
        'taxi-direction': 'rightward',
        'taxi-turn': '60%',
        'label': 'data(label)',
        'font-size': '9px',
        'color': '#666',
        'text-background-color': '#fff',
        'text-background-opacity': 0.8,
        'text-background-padding': '2px',
      }
    },
    {
      selector: 'edge[?fan_out]',
      style: { 'line-style': 'dashed', 'width': 2.5 }
    },
    {
      selector: 'edge[role="control"]',
      style: {
        'line-style': 'dotted',
        'line-color': '#8e44ad',
        'target-arrow-color': '#8e44ad',
        'width': 1.5,
        'opacity': 0.75,
        'font-size': '8px',
        'color': '#8e44ad',
      }
    },
    {
      selector: 'edge.flowing',
      style: {
        'line-style': 'dashed',
        'line-dash-pattern': [10, 5],
        'line-dash-offset': 0,
        'width': 2.5,
        'opacity': 1.0,
      }
    },
    {
      selector: 'node[?external]',
      style: {
        'border-style': 'dashed',
        'border-width': 2.5,
        'border-color': '#aaa',
        'font-style': 'italic',
        'opacity': 0.85,
      }
    },
    {
      selector: '.highlighted',
      style: { 'line-color': '#e67e22', 'target-arrow-color': '#e67e22',
                'background-color': '#e67e22', 'border-color': '#e67e22', 'width': 3 }
    },
    {
      selector: '.dimmed',
      style: { 'opacity': 0.25 }
    },
  ],
});

// ── Edge stagger: prevent overlapping taxi routes ─────────────────
// Group edges by (source topological level → target topological level).
// Edges in the same group share an identical horizontal path segment,
// so we spread their taxi-turn values (20 %…80 %) to push the vertical
// segment to different x positions.
(function staggerEdgesByLevelPair() {
  var X_STEP = 200;

  // Determine topological level of each node from its preset x position
  var nodeLevel = {};
  cy.nodes().forEach(function(n) {
    nodeLevel[n.id()] = Math.round(n.position('x') / X_STEP);
  });

  // Group by "srcLevel->tgtLevel"
  var pairMap = {};
  cy.edges().forEach(function(e) {
    var key = nodeLevel[e.data('source')] + '->' + nodeLevel[e.data('target')];
    if (!pairMap[key]) pairMap[key] = [];
    pairMap[key].push(e);
  });

  Object.values(pairMap).forEach(function(edges) {
    if (edges.length < 2) return;
    var n = edges.length;
    edges.forEach(function(e, i) {
      // Spread turns evenly from 20 % to 80 %
      var turn = 20 + i * (60 / (n - 1));
      e.style('taxi-turn', Math.round(turn) + '%');
    });
  });
})();

// ── Color data edges by source node's layer ──────────────────────
// Gives each data path a distinct color matching its producer IP's layer.
// External nodes (sensor, display) use the EXTERNAL_COLOR gray.
var LAYER_EDGE_COLOR = {
  app: '#8e44ad', framework: '#2980b9', hal: '#16a085',
  kernel: '#2c3e50', hw: '#c0622b', memory: '#1e8449',
};
cy.edges('[role="data"]').forEach(function(edge) {
  var src = cy.getElementById(edge.data('source'));
  var color = src.data('external') ? '#7f8c8d'
            : (LAYER_EDGE_COLOR[src.data('layer')] || '#aab');
  edge.style({ 'line-color': color, 'target-arrow-color': color });
});

// Draw layer lane lines as background overlay
drawLaneDividers();
cy.on('resize pan zoom', drawLaneDividers);  // unified — was split across two registrations

function drawLaneDividers() {
  document.querySelectorAll('.lane-overlay').forEach(function(el) { el.remove(); });
  var container = document.getElementById('cy');
  var containerH = container.clientHeight;

  // ── Layer background color bands (LAYER_BANDS defined at module scope above) ──
  LAYER_BANDS.forEach(function(band) {
    var top    = cy.pan().y + band.y1 * cy.zoom();
    var bottom = cy.pan().y + band.y2 * cy.zoom();
    var visTop    = Math.max(0, top);
    var visBottom = Math.min(containerH, bottom);
    if (visBottom <= visTop) return;
    var div = document.createElement('div');
    div.className = 'lane-overlay';
    div.style.cssText = [
      'position:absolute', 'left:0', 'right:0',
      'background:' + band.color,
      'pointer-events:none',
      'z-index:0',
      'top:' + visTop + 'px',
      'height:' + (visBottom - visTop) + 'px',
    ].join(';');
    container.appendChild(div);
  });

  // ── Horizontal lane separator lines ──────────────────────────
  var separators = [
    {y: 80,  style: '1px dashed #dde'},
    {y: 240, style: '1px dashed #dde'},
    {y: 400, style: '1px dashed #dde'},
    {y: 580, style: '2px solid #c8ccd4'},  // SW ↔ HW boundary
    {y: 830, style: '1px dashed #cce'},   // HW ↔ Buffer boundary
  ];
  separators.forEach(function(sep) {
    var renderedY = cy.pan().y + sep.y * cy.zoom();
    var line = document.createElement('div');
    line.className = 'lane-overlay';
    line.style.cssText = 'position:absolute;left:0;right:0;border-top:' + sep.style + ';pointer-events:none;z-index:5;top:' + renderedY + 'px';
    container.appendChild(line);
  });

  // ── Y-axis layer labels (left side) ──────────────────────────
  var layerLabels = [
    {y: LAYER_Y.app,       text: 'App',       color: '#8e44ad'},
    {y: LAYER_Y.framework, text: 'Framework', color: '#2980b9'},
    {y: LAYER_Y.hal,       text: 'HAL',       color: '#16a085'},
    {y: LAYER_Y.kernel,    text: 'Kernel',    color: '#2c3e50'},
    {y: LAYER_Y.hw,        text: 'HW',        color: '#E67E22'},
    {y: LAYER_Y.memory,    text: 'Buffer',    color: '#27AE60'},
  ];
  layerLabels.forEach(function(l) {
    var renderedY = cy.pan().y + l.y * cy.zoom();
    var lbl = document.createElement('div');
    lbl.className = 'lane-overlay lane-label';
    lbl.textContent = l.text;
    lbl.style.cssText = 'position:absolute;left:4px;font-size:10px;font-weight:600;color:' + l.color + ';pointer-events:none;z-index:10;top:' + (renderedY - 8) + 'px';
    container.appendChild(lbl);
  });

  // ── X-axis: pipeline stage markers ───────────────────────────
  var xSet = {};
  ELEMENTS.forEach(function(el) {
    if (el.position !== undefined) {
      var xModel = el.position.x;
      if (!(xModel in xSet)) xSet[xModel] = 0;
      xSet[xModel]++;
    }
  });
  var xValues = Object.keys(xSet).map(Number).sort(function(a,b){return a-b;});

  xValues.forEach(function(xModel, idx) {
    var renderedX = cy.pan().x + xModel * cy.zoom();
    if (renderedX < 0 || renderedX > container.clientWidth) return;

    var vline = document.createElement('div');
    vline.className = 'lane-overlay';
    vline.style.cssText = 'position:absolute;top:0;bottom:0;border-left:1px dotted #dde;pointer-events:none;z-index:4;left:' + renderedX + 'px';
    container.appendChild(vline);

    var stgLbl = document.createElement('div');
    stgLbl.className = 'lane-overlay';
    stgLbl.textContent = 'S' + idx;
    stgLbl.title = 'Pipeline stage ' + idx + ' (topological order)';
    stgLbl.style.cssText = [
      'position:absolute', 'font-size:9px', 'color:#bbb',
      'pointer-events:none', 'z-index:10',
      'left:' + (renderedX + 3) + 'px', 'bottom:4px', 'white-space:nowrap',
    ].join(';');
    container.appendChild(stgLbl);
  });

  // ── X-axis time budget note (bottom-right) ───────────────────
  var period = SCENARIO.scenario && SCENARIO.scenario.output_period_ms;
  var budget = SCENARIO.scenario && SCENARIO.scenario.budget_ms;
  if (period || budget) {
    var note = document.createElement('div');
    note.className = 'lane-overlay';
    var parts = [];
    if (period) parts.push('period: ' + period + 'ms');
    if (budget) parts.push('budget: ' + budget + 'ms');
    note.textContent = parts.join(' / ') + '  (x = pipeline order, not actual time)';
    note.style.cssText = 'position:absolute;right:8px;bottom:4px;font-size:9px;color:#bbb;pointer-events:none;z-index:10;white-space:nowrap';
    container.appendChild(note);
  }
}

// ── Node badges: C / L (top-left) · R (top-right) ────────────────
// C / L: compression / LLC — left side of buffer nodes
// R: rotation — right side of buffer nodes (indicates which buffer DPU rotates)
var BADGE_DEFS_LEFT = [
  { key: 'compression', text: 'C', color: '#2471a3', title: 'Compression (AFBC / SBWC)' },
  { key: 'llc',         text: 'L', color: '#117a65', title: 'Last Level Cache (LLC)' },
];
var BADGE_DEFS_RIGHT = [
  { key: 'rotation', text: 'R', color: '#922b21', title: 'Rotation enabled (DPU rotates this buffer)' },
];

function createBadgeEl(badge, x, y) {
  var el = document.createElement('div');
  el.className = 'node-badge';
  el.textContent = badge.text;
  el.title = badge.title;
  el.style.background = badge.color;
  el.style.left = x + 'px';
  el.style.top  = y + 'px';
  return el;
}

function drawNodeBadges() {
  document.querySelectorAll('.node-badge').forEach(function(el) { el.remove(); });
  var container = document.getElementById('cy');
  cy.nodes().forEach(function(node) {
    if (node.style('display') === 'none') return;
    var d  = node.data();
    var bb = node.renderedBoundingBox({ includeLabels: false });
    var top = bb.y1 + 2;
    BADGE_DEFS_LEFT.filter(function(b) { return d[b.key] === true; })
      .forEach(function(badge, i) {
        container.appendChild(createBadgeEl(badge, bb.x1 + 2 + i * 15, top));
      });
    BADGE_DEFS_RIGHT.filter(function(b) { return d[b.key] === true; })
      .forEach(function(badge, i) {
        container.appendChild(createBadgeEl(badge, bb.x2 - 15 - i * 15, top));
      });
  });
}

drawNodeBadges();
cy.on('pan zoom resize', drawNodeBadges);
cy.on('drag', 'node', drawNodeBadges);

// ── Interactions ─────────────────────────────────────────────────

cy.on('tap', 'node', function(evt) {
  clearHighlight();
  showNodeDetail(evt.target.data());
});

cy.on('tap', 'edge', function(evt) {
  clearHighlight();
  var edge = evt.target;
  cy.elements().addClass('dimmed');
  cy.getElementById(edge.data('source')).removeClass('dimmed').addClass('highlighted');
  cy.getElementById(edge.data('target')).removeClass('dimmed').addClass('highlighted');
  edge.removeClass('dimmed').addClass('highlighted');
  showEdgeDetail(edge.data());
});

cy.on('tap', function(evt) {
  if (evt.target === cy) { clearHighlight(); resetPanel(); }
});

function clearHighlight() { cy.elements().removeClass('highlighted dimmed'); }

function resetPanel() {
  if (MODE === 'executive') {
    showScenarioOverview();
  } else {
    // In architect mode show empty hint + keep summary tables visible
    var panel = document.getElementById('detail-panel');
    panel.querySelector('h3').textContent = 'Node / Edge Detail';
    var hint = panel.querySelector('.empty-hint');
    if (hint) hint.style.display = '';
  }
}

function showScenarioOverview() {
  var sc = SCENARIO.scenario || {};
  var html = '<h3>' + escHtml(sc.name || 'Scenario') + '</h3>';
  if (sc.description) {
    html += '<p style="font-size:12px;color:#555;line-height:1.5;margin-bottom:10px">' + escHtml(sc.description) + '</p>';
  }
  html += '<table class="prop-table">';
  html += row('Category', sc.category || '—');
  html += row('Version', sc.version || '—');
  html += row('Period', (sc.output_period_ms || '—') + ' ms');
  html += row('Budget', (sc.budget_ms || '—') + ' ms');
  if (sc.pipeline_latency_frames != null) html += row('Latency', sc.pipeline_latency_frames + ' frames');
  html += '</table>';
  var risks = sc.risks || [];
  if (risks.length) {
    html += '<div class="risk-section"><strong style="font-size:12px">Risks</strong>';
    risks.forEach(function(r) {
      html += '<div class="risk-item risk-' + r.severity + '"><strong>' + r.severity.toUpperCase() + '</strong> ' + escHtml(r.description) + '</div>';
    });
    html += '</div>';
  }
  // Replace only the top part of the panel, keep architect summary div intact
  var panel = document.getElementById('detail-panel');
  var ipSummary = document.getElementById('ip-summary');
  panel.innerHTML = html;
  if (ipSummary) panel.appendChild(ipSummary);
}

// ── DPU Composition panel (WinScope-style layer layout) ──────────────────
var PLANE_COLORS = [
  { bg: 'rgba(41,128,185,0.55)',  border: '#2471a3' },  // blue  — preview
  { bg: 'rgba(230,126,34,0.50)', border: '#ca6f1e' },  // orange — UI overlay
  { bg: 'rgba(39,174,96,0.50)',  border: '#1e8449' },  // green  — 3rd layer
  { bg: 'rgba(142,68,173,0.50)', border: '#7d3c98' },  // purple — 4th layer
];

function buildDpuCompositionHtml(comp) {
  var ds   = comp.display_size;
  var PREVIEW_W = 130;
  var SCALE     = PREVIEW_W / ds.w;
  var PREVIEW_H = Math.round(ds.h * SCALE);

  var planes = comp.planes;  // pre-sorted by z_order at init (see DPU_COMP_MAP setup)

  var html = '<div style="margin-top:14px;border-top:2px solid #e0e4ea;padding-top:12px">';
  html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:2px">';
  html += '<strong style="font-size:12px;color:#1a2a4a">DPU Composition</strong>';
  html += '<span style="font-size:10px;color:#999">' + ds.w + ' × ' + ds.h + '</span>';
  html += '</div>';
  if (comp.display_name) {
    html += '<div style="font-size:10px;color:#555;margin-bottom:8px">' + escHtml(comp.display_name) + '</div>';
  }

  html += '<div style="display:flex;gap:12px;align-items:flex-start">';

  // ── Left: miniature display preview ──
  html += '<div style="flex-shrink:0">';
  html += '<div style="font-size:9px;color:#aaa;text-align:center;margin-bottom:2px">Display</div>';
  html += '<div style="position:relative;width:' + PREVIEW_W + 'px;height:' + PREVIEW_H + 'px;';
  html += 'background:#0d0d0d;border:1.5px solid #444;border-radius:4px;overflow:hidden">';

  planes.forEach(function(plane, i) {
    var c  = PLANE_COLORS[i % PLANE_COLORS.length];
    var df = plane.display_frame;
    var px = Math.round(df.x * SCALE);
    var py = Math.round(df.y * SCALE);
    var pw = Math.max(1, Math.round(df.w * SCALE));
    var ph = Math.max(1, Math.round(df.h * SCALE));
    html += '<div style="position:absolute;';
    html += 'left:' + px + 'px;top:' + py + 'px;width:' + pw + 'px;height:' + ph + 'px;';
    html += 'background:' + c.bg + ';box-sizing:border-box;border:1px solid ' + c.border + ';';
    html += 'font-size:7px;color:#fff;overflow:hidden;padding:2px;" ';
    html += 'title="' + escHtml(plane.name) + '">';
    html += '<span style="opacity:0.9;white-space:nowrap">' + escHtml(plane.name) + '</span>';
    html += '</div>';
  });

  // Guide lines for status bar (top) and controls (bottom) — only when >2 planes or standard layout
  var statusH = Math.round(96 * SCALE);
  html += '<div style="position:absolute;left:0;right:0;top:' + statusH + 'px;';
  html += 'border-top:1px dashed rgba(255,255,255,0.2);pointer-events:none"></div>';

  html += '</div>';  // end display box
  // Screen labels
  html += '<div style="display:flex;justify-content:space-between;font-size:8px;color:#aaa;margin-top:2px">';
  html += '<span>x=0</span><span>x=' + ds.w + '</span></div>';
  html += '</div>';  // end left

  // ── Right: per-plane detail cards ──
  html += '<div style="flex:1;min-width:0">';
  planes.forEach(function(plane, i) {
    var c  = PLANE_COLORS[i % PLANE_COLORS.length];
    var df = plane.display_frame;
    var sc = plane.source_crop;
    html += '<div style="margin-bottom:10px;padding:6px 8px;border-radius:4px;';
    html += 'border-left:3px solid ' + c.border + ';background:#f8f9fb">';
    html += '<div style="font-size:11px;font-weight:600;color:#1a2a4a;margin-bottom:4px">';
    html += '<span style="display:inline-block;width:8px;height:8px;border-radius:2px;';
    html += 'background:' + c.bg + ';border:1px solid ' + c.border + ';margin-right:4px;vertical-align:middle"></span>';
    html += escHtml(plane.name) + '</div>';

    html += '<table style="width:100%;font-size:10px;border-collapse:collapse">';
    html += '<tr><td style="color:#777;padding:1px 4px 1px 0;width:44%">buffer</td>';
    html += '<td style="font-weight:600">' + escHtml(plane.buffer) + '</td></tr>';
    html += '<tr><td style="color:#777;padding:1px 4px 1px 0">src crop</td>';
    html += '<td>' + sc.x + ',' + sc.y + '&nbsp;&nbsp;' + sc.w + '×' + sc.h + '</td></tr>';
    html += '<tr><td style="color:#777;padding:1px 4px 1px 0">dst frame</td>';
    html += '<td>' + df.x + ',' + df.y + '&nbsp;&nbsp;' + df.w + '×' + df.h + '</td></tr>';
    if (plane.transform && plane.transform !== 'NONE') {
      html += '<tr><td style="color:#777;padding:1px 4px 1px 0">transform</td>';
      html += '<td style="color:#c0392b;font-weight:600">' + escHtml(plane.transform) + '</td></tr>';
    }
    html += '</table>';
    html += '</div>';
  });
  html += '</div>';  // end right

  html += '</div>';  // end flex container
  html += '</div>';  // end section
  return html;
}

function showNodeDetail(data) {
  var html = '<h3>' + escHtml(data.label) + '</h3>';
  html += '<table class="prop-table">';
  html += row('ID', data.id);
  html += row('Type', data.type);
  html += row('Layer', data.layer);
  if (data.external) html += row('Boundary', '<span style="color:#c0392b;font-weight:600">External (off-SoC)</span>');
  if (data.compression != null) html += row('Compression', data.compression
    ? '<span style="color:#2471a3;font-weight:600">&#9646; Enabled (AFBC/SBWC)</span>'
    : '<span style="color:#888">Disabled</span>');
  if (data.llc != null) html += row('LLC', data.llc
    ? '<span style="color:#117a65;font-weight:600">&#9646; Enabled</span>'
    : '<span style="color:#888">Disabled</span>');
  if (data.rotation != null) html += row('Rotation', data.rotation
    ? '<span style="color:#922b21;font-weight:600">&#9646; Enabled</span>'
    : '<span style="color:#888">Disabled</span>');
  if (data.comment) html += row('Comment', data.comment);
  html += '</table>';

  // DPU composition panel — O(1) lookup via DPU_COMP_MAP (keyed by display_id at init)
  var dpuComp = DPU_COMP_MAP[data.id];
  if (dpuComp) html += buildDpuCompositionHtml(dpuComp);

  // IP activity detail — Architect mode only
  if (MODE === 'architect') {
    var ipSpec = getIPInfo(data.id);
    if (ipSpec) {
      html += buildIPDetailHtml(ipSpec);
      if (ipSpec._review_flags && ipSpec._review_flags.length) {
        ipSpec._review_flags.forEach(function(f) {
          html += '<span class="review-flag">⚠ ' + escHtml(f.field) + ': ' + escHtml(f.reason) + '</span>';
        });
      }
    }
  }

  var panel = document.getElementById('detail-panel');
  var ipSummary = document.getElementById('ip-summary');
  panel.innerHTML = html;
  if (ipSummary) panel.appendChild(ipSummary);
}

function showEdgeDetail(data) {
  var html = '<h3>Edge: ' + escHtml(data.id) + '</h3>';
  html += '<table class="prop-table">';
  html += row('Source', data.source);
  html += row('Target', data.target);
  if (data.label) html += row('Buffer', data.label);
  if (data.fan_out) html += row('Fan-out', '✓');
  if (data.branch_condition) html += row('Condition', data.branch_condition);
  html += '</table>';
  var panel = document.getElementById('detail-panel');
  var ipSummary = document.getElementById('ip-summary');
  panel.innerHTML = html;
  if (ipSummary) panel.appendChild(ipSummary);
}

function getIPInfo(nodeId) {
  return IP_SPEC_MAP[nodeId] || null;
}

function getActiveMode(spec) {
  var modeId = ACTIVE_IP_MODES[spec.id] || 'default';
  if (modeId === 'default') return spec.default;
  var m = (spec.modes || []).find(function(m) { return m.id === modeId; });
  return m || spec.default;
}

function buildIPDetailHtml(spec) {
  var mode = getActiveMode(spec);
  var html = '<div id="variant-section">';
  html += '<strong style="font-size:12px">IP Activity</strong>';
  if (mode.id !== 'default') {
    html += '<span style="font-size:10px;color:#c0622b;margin-left:6px;font-weight:600">mode: ' + escHtml(mode.id) + '</span>';
  }
  html += '<table class="prop-table" style="margin-top:6px">';
  if (mode.freq_mhz    != null) html += row('freq',    mode.freq_mhz    + ' MHz');
  if (mode.power_mA    != null) html += row('power',   mode.power_mA    + ' mA');
  if (mode.bw_read_gbps  != null) html += row('BW read',  mode.bw_read_gbps  + ' GB/s');
  if (mode.bw_write_gbps != null) html += row('BW write', mode.bw_write_gbps + ' GB/s');
  if (mode.exec_time_ms  != null) html += row('exec time', mode.exec_time_ms + ' ms');
  html += row('source', mode.source || '—');
  html += '</table>';
  // Other available modes
  if (spec.modes && spec.modes.length) {
    html += '<div style="margin-top:8px;font-size:10px;color:#888"><strong>Available modes:</strong> ';
    html += spec.modes.map(function(m) {
      return '<span style="background:#f4f6f9;border-radius:3px;padding:1px 5px;margin-right:3px">' +
        escHtml(m.id) + (m.condition ? ' (' + escHtml(m.condition) + ')' : '') + '</span>';
    }).join('');
    html += '</div>';
  }
  html += '</div>';
  return html;
}

// I4: Layer toggle
function toggleLayer(btn) {
  var layer = btn.getAttribute('data-layer');
  btn.classList.toggle('active');
  cy.nodes('[layer="' + layer + '"]').style('display', btn.classList.contains('active') ? 'element' : 'none');
  drawNodeBadges();
}

// ── Mode switch ──────────────────────────────────────────────────
function switchMode(newMode) {
  if (MODE === newMode) return;
  MODE = newMode;

  // Update tab active state
  document.getElementById('tab-executive').classList.toggle('active', MODE === 'executive');
  document.getElementById('tab-architect').classList.toggle('active', MODE === 'architect');

  // Toolbar: mode label + architect IP selector
  var modeLabel = document.getElementById('toolbar-mode-label');
  var archToolbar = document.getElementById('architect-toolbar');
  if (MODE === 'executive') {
    modeLabel.innerHTML = 'Executive View \u2014 scenario overview &amp; risk summary';
    if (archToolbar) archToolbar.style.display = 'none';
  } else {
    modeLabel.innerHTML = 'Architect View \u2014 IP operating conditions &amp; variant comparison';
    if (archToolbar) { archToolbar.style.display = 'flex'; }
    // Reset IP selector
    var ipSel = document.getElementById('ip-select');
    if (ipSel) { ipSel.value = ''; highlightIP(''); }
  }

  // Detail panel: IP summary table visibility
  var ipSummary = document.getElementById('ip-summary');
  if (ipSummary) ipSummary.style.display = MODE === 'architect' ? '' : 'none';

  clearHighlight();
  resetPanel();
}

// IP focus (Architect)
function highlightIP(ipId) {
  cy.elements().removeClass('highlighted dimmed');
  if (!ipId) return;
  cy.elements().addClass('dimmed');
  var node = cy.getElementById(ipId);
  if (node.length) {
    node.removeClass('dimmed').addClass('highlighted');
    node.neighborhood().removeClass('dimmed');
  }
}

// ── Utilities ────────────────────────────────────────────────────
function row(k, v) {
  return '<tr><td>' + escHtml(String(k)) + '</td><td>' + String(v) + '</td></tr>';
}
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Data flow animation ───────────────────────────────────────────
// Animates line-dash-offset on all role="data" edges to show data flow.
// Decreasing offset = pattern moves source→target direction.
var _flowActive = false;
var _flowRaf    = null;
var _flowOffset = 0;

function toggleDataFlow() {
  _flowActive ? _stopDataFlow() : _startDataFlow();
}

function _startDataFlow() {
  _flowActive = true;
  document.getElementById('flow-btn').innerHTML = '&#9646;&#9646; Flow';
  document.getElementById('flow-btn').style.background = '#e8f4e8';
  cy.edges('[role="data"]').addClass('flowing');
  _animateFlow();
}

function _stopDataFlow() {
  _flowActive = false;
  document.getElementById('flow-btn').innerHTML = '&#9654; Flow';
  document.getElementById('flow-btn').style.background = '#f4f6f9';
  if (_flowRaf) { cancelAnimationFrame(_flowRaf); _flowRaf = null; }
  cy.edges('.flowing').removeClass('flowing');
}

function _animateFlow() {
  _flowOffset -= 0.2;
  if (_flowOffset < -1000) _flowOffset = 0;
  var edges = cy.edges('.flowing');
  cy.batch(function() {
    edges.forEach(function(e) { e.style('line-dash-offset', _flowOffset); });
  });
  _flowRaf = requestAnimationFrame(_animateFlow);
}

// Fit graph on load; show executive overview by default
cy.ready(function() { cy.fit(undefined, 40); drawLaneDividers(); resetPanel(); });
</script>

