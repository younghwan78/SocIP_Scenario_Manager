+// ── Color data edges by source node's layer ──────────────────────
+// Gives each data path a distinct color matching its producer IP's layer.
+// External nodes (sensor, display) use the EXTERNAL_COLOR gray.
+var LAYER_EDGE_COLOR = {
+  app: '#8e44ad', framework: '#2980b9', hal: '#16a085',
+  kernel: '#2c3e50', hw: '#c0622b', memory: '#1e8449',
+};
+cy.edges('[role="data"]').forEach(function(edge) {
+  var src = cy.getElementById(edge.data('source'));
+  var color = src.data('external') ? '#7f8c8d'
+            : (LAYER_EDGE_COLOR[src.data('layer')] || '#aab');
+  edge.style({ 'line-color': color, 'target-arrow-color': color });
+});
