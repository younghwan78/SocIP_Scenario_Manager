From 95741bae738f8b32b3a944c29ba2b14123d7fe0b Mon Sep 17 00:00:00 2001
From: YounghwanJoo <neokein@gmail.com>
Date: Sun, 15 Mar 2026 23:41:33 +0900
Subject: [PATCH 1/3] Add C/L/R badge overlays to buffer and HW IP nodes

Buffer nodes now carry compression and llc boolean fields;
HW IP nodes (DPU) carry rotation. Cytoscape renders small
color-coded badges (C=blue, L=teal, R=red) at the top-left
corner of each node when the flag is true, repositioned on
pan/zoom. Node detail panel shows the values with color
indicators. uhd30_recording.yaml updated with realistic
values: enc_buf (no compression/LLC), preview_buf (AFBC+LLC),
bitstream (no compression/LLC), DPU (rotation enabled).
---
 scenarios/usecase/uhd30_recording.yaml     | 15 ++++--
 src/mmscenario/schema/models.py            |  5 +-
 src/mmscenario/view/data_prep.py           | 31 +++++++------
 src/mmscenario/view/templates/base.html.j2 | 54 ++++++++++++++++++++++
 4 files changed, 87 insertions(+), 18 deletions(-)

diff --git a/scenarios/usecase/uhd30_recording.yaml b/scenarios/usecase/uhd30_recording.yaml
index f618a05..48bef12 100644
--- a/scenarios/usecase/uhd30_recording.yaml
+++ b/scenarios/usecase/uhd30_recording.yaml
@@ -147,26 +147,33 @@ pipeline:
       type: hw_ip
       label: DPU
       layer: hw
-      comment: "Display Processing Unit — HW overlay path. GPU composition is the risk variant."
+      rotation: true
+      comment: "Display Processing Unit — HW overlay path. Rotation enabled (portrait recording). GPU composition is the risk variant."
 
     # ── Memory / Buffer layer ──────────────────────────────────────────────────
     - id: enc_buf
       type: buffer
       label: "Encode Buffer\nNV12 · 3840×2160"
       layer: memory
-      comment: "ISP M2M output DMA-buf — shared between ISP (producer) and MFC (consumer)"
+      compression: false
+      llc: false
+      comment: "ISP M2M output → MFC. No compression (MFC requires raw NV12). No LLC (streaming write, sequential)."
 
     - id: preview_buf
       type: buffer
       label: "Preview Buffer\nNV12 · 1920×1080"
       layer: memory
-      comment: "ISP preview output — shared between ISP (producer) and DPU via SurfaceFlinger"
+      compression: true
+      llc: true
+      comment: "ISP preview output → DPU. AFBC compressed (reduces BW ~40%). LLC enabled (DPU reads repeatedly per scanout)."
 
     - id: bitstream
       type: buffer
       label: "Encoded Bitstream\n(H.265 / AV1)"
       layer: memory
-      comment: "MFC output buffer — picked up by Codec2 HAL and handed to MediaMuxer"
+      compression: false
+      llc: false
+      comment: "MFC output → MediaMuxer file write. Compressed bitstream (codec-level, not memory compression). No LLC (sequential file write)."
 
   edges:
     # ══ SW control stack: camera capture path ════════════════════════════════
