+# ── DPU composition: display layout for each HW overlay plane ─────────────
+# List enables multi-display scenarios (foldable: display0, display1).
+# display_id must match a pipeline node id.
+# source_crop:   region of source buffer DPU reads (pre-transform coordinates)
+# display_frame: destination on the physical display (post-transform coordinates)
+dpu_compositions:
+  - display_id: display
+    display_name: "Main Display (FHD+)"
+    display_size: {w: 1080, h: 2340}
+    planes:
+      - name: "Camera Preview"
+        buffer: preview_buf
+        # ISP outputs landscape 1920×1080; DPU rotates 90° CW → portrait 1080×1920.
+        # Placed below the status bar (y=96), occupies y=96–2016 (1920 px).
+        source_crop:   {x: 0, y:    0, w: 1920, h: 1080}
+        display_frame: {x: 0, y:   96, w: 1080, h: 1920}
+        transform: ROT_90
+        z_order: 0
+        plane_alpha: 1.0
+
+      - name: "Status Bar"
+        buffer: status_buf
+        # Dedicated 1080×96 SystemUI surface — DPU reads the full buffer.
+        source_crop:   {x: 0, y: 0, w: 1080, h:  96}
+        display_frame: {x: 0, y: 0, w: 1080, h:  96}
+        transform: NONE
+        z_order: 1
+        plane_alpha: 1.0
+
+      - name: "Camera Controls"
+        buffer: controls_buf
+        # Dedicated 1080×324 CameraApp surface — shutter, mode switcher, gallery.
+        source_crop:   {x: 0, y:    0, w: 1080, h: 324}
+        display_frame: {x: 0, y: 2016, w: 1080, h: 324}
+        transform: NONE
+        z_order: 2
+        plane_alpha: 1.0
